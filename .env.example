# Upstash Redis (auto-injected when you add the Upstash integration from the Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin dashboard password — choose a strong value. Required to view /admin results.
ADMIN_KEY=change-me-to-a-strong-password

# NOTE: If the Upstash vars are left blank, the app falls back to an in-memory
# store so you can run it locally without any setup. In-memory data is NOT
# persisted across restarts and is per-instance — use Upstash for production.
